{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specrail.local/schemas/review_result.schema.json",
  "title": "Terminal Review Result v2",
  "type": "object",
  "required": [
    "artifact_id",
    "pr",
    "reviewer_lane",
    "producer_identity",
    "review_source",
    "head_sha",
    "review_started_at",
    "review_completed_at",
    "status",
    "verdict",
    "human_final_review_required",
    "findings",
    "prior_findings",
    "body",
    "comments"
  ],
  "additionalProperties": false,
  "allOf": [
    {
      "if": {"required": ["content_binding_version"]},
      "then": {
        "required": [
          "covered_categories",
          "content_bindings",
          "content_binding_evidence"
        ]
      },
      "else": {
        "properties": {
          "covered_categories": {"const": null},
          "content_bindings": {"const": null},
          "content_binding_evidence": {"const": null}
        }
      }
    },
    {
      "if": {
        "properties": {"round_policy_version": {"const": 1}},
        "required": ["round_policy_version"]
      },
      "then": {
        "required": ["review_round", "review_mode"],
        "properties": {
          "prior_findings": {
            "items": {
              "type": "object",
              "required": ["finding_id", "source_artifact_id", "status", "evidence_pointer"],
              "additionalProperties": false,
              "properties": {
                "finding_id": {"type": "string", "minLength": 1},
                "source_artifact_id": {"type": "string", "minLength": 1},
                "status": {"enum": ["resolved", "unresolved", "obsolete"]},
                "evidence_pointer": {
                  "anyOf": [
                    {
                      "type": "object",
                      "required": ["kind", "value"],
                      "additionalProperties": false,
                      "properties": {
                        "kind": {"const": "thread"},
                        "value": {"type": "string", "pattern": "^PRRT_[A-Za-z0-9_-]+$"}
                      }
                    },
                    {
                      "type": "object",
                      "required": ["kind", "value"],
                      "additionalProperties": false,
                      "properties": {
                        "kind": {"const": "comment"},
                        "value": {"type": "string", "pattern": "^PRRC_[A-Za-z0-9_-]+$"}
                      }
                    },
                    {
                      "type": "object",
                      "required": ["kind", "value"],
                      "additionalProperties": false,
                      "properties": {
                        "kind": {"const": "artifact"},
                        "value": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"}
                      }
                    },
                    {
                      "type": "object",
                      "required": ["kind", "value"],
                      "additionalProperties": false,
                      "properties": {
                        "kind": {"const": "commit"},
                        "value": {"type": "string", "pattern": "^[0-9a-fA-F]{40}$"}
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {"review_round": {"minimum": 2}},
              "required": ["review_round"]
            },
            "then": {
              "required": ["base_head_sha", "diff_sha256"],
              "properties": {"review_mode": {"enum": ["resumed", "diff_only"]}}
            }
          }
        ]
      },
      "else": {
        "properties": {
          "prior_findings": {
            "items": {
              "type": "object",
              "required": ["id", "source_head_sha", "summary", "status"],
              "additionalProperties": false,
              "allOf": [
                {
                  "if": {
                    "properties": {"status": {"enum": ["resolved", "obsolete"]}},
                    "required": ["status"]
                  },
                  "then": {"required": ["closure_evidence"]}
                }
              ],
              "properties": {
                "id": {"type": "string", "minLength": 1},
                "source_head_sha": {"type": "string", "pattern": "^[0-9a-fA-F]{40}$"},
                "summary": {"type": "string", "minLength": 1},
                "status": {"enum": ["resolved", "unresolved", "obsolete"]},
                "closure_evidence": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    },
    {
      "if": {"required": ["review_round"]},
      "then": {"required": ["review_mode"]}
    },
    {
      "if": {"required": ["review_mode"]},
      "then": {"required": ["review_round"]}
    },
    {
      "if": {
        "properties": {"gate_status": {"const": "unavailable"}},
        "required": ["gate_status"]
      },
      "then": {
        "required": ["gate_authorization"],
        "properties": {
          "body": {
            "pattern": "(^|\\n)## Summary[ \\t]*(\\n|$)(?:(?!\\n## )[\\s\\S])*SpecRail gate status: unavailable"
          }
        }
      }
    },
    {
      "if": {"required": ["gate_authorization"]},
      "then": {
        "required": ["gate_status"],
        "properties": {"gate_status": {"const": "unavailable"}}
      }
    },
    {
      "if": {
        "properties": {
          "body": {"pattern": "SpecRail gate status: unavailable"}
        },
        "required": ["body"]
      },
      "then": {
        "required": ["gate_status", "gate_authorization"],
        "properties": {"gate_status": {"const": "unavailable"}}
      }
    },
    {
      "if": {
        "properties": {"review_completed_at": {"type": "null"}},
        "required": ["review_completed_at"]
      },
      "then": {"properties": {"status": {"const": "pending"}}}
    }
  ],
  "properties": {
    "content_binding_version": {"const": 1},
    "covered_categories": {
      "type": "array",
      "minItems": 1,
      "items": {"enum": ["code_inputs", "spec_files", "pr_metadata"]}
    },
    "content_bindings": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "code_inputs": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "spec_files": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "pr_metadata": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "content_binding_evidence": {
      "type": "object",
      "required": ["artifact_id", "path", "sha256"],
      "additionalProperties": false,
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "artifact_id": {"type": "string", "minLength": 1},
    "pr": {"type": "integer", "minimum": 1},
    "reviewer_lane": {"type": "string", "minLength": 1},
    "producer_identity": {"type": "string", "minLength": 1},
    "review_source": {
      "enum": ["independent_lane", "self_review"]
    },
    "review_execution": {
      "enum": ["local", "hosted"],
      "description": "Execution location. local artifacts may serve as primary review; hosted artifacts are supplemental only and fail the primary review semantic gate."
    },
    "head_sha": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{40}$"
    },
    "review_started_at": {"type": "string", "minLength": 1},
    "review_completed_at": {
      "anyOf": [
        {"type": "string", "minLength": 1},
        {"type": "null"}
      ]
    },
    "status": {
      "enum": ["completed", "pending", "failed", "cancelled", "superseded"]
    },
    "verdict": {
      "enum": ["clean", "non_blocking", "changes_requested", "blocking"]
    },
    "human_final_review_required": {"type": "boolean"},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "actionable", "summary"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "severity": {
            "enum": ["critical", "important", "suggestion", "nit"]
          },
          "actionable": {"type": "boolean"},
          "summary": {"type": "string", "minLength": 1}
        }
      }
    },
    "prior_findings": {
      "type": "array"
    },
    "round_policy_version": {"const": 1},
    "review_round": {"type": "integer", "minimum": 1},
    "review_mode": {"enum": ["full", "resumed", "diff_only"]},
    "base_head_sha": {
      "anyOf": [
        {"type": "string", "pattern": "^[0-9a-fA-F]{40}$"},
        {"type": "null"}
      ]
    },
    "diff_sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
    "round_cap_escalation": {
      "type": "object",
      "required": ["authorization_id", "unresolved_findings"],
      "additionalProperties": false,
      "properties": {
        "authorization_id": {"type": "string", "minLength": 1},
        "unresolved_findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["finding_id", "source_artifact_id"],
            "additionalProperties": false,
            "properties": {
              "finding_id": {"type": "string", "minLength": 1},
              "source_artifact_id": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "human_full_review_request": {
      "anyOf": [
        {"type": "string", "minLength": 1},
        {"type": "null"}
      ]
    },
    "gate_status": {"enum": ["gated", "unavailable"]},
    "gate_authorization": {"type": "string", "minLength": 1, "pattern": "\\S"},
    "body": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        {"pattern": "(^|\\n)## Summary[ \\t]*(\\n|$)"},
        {"pattern": "(^|\\n)## Verdict[ \\t]*(\\n|$)"}
      ]
    },
    "comments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "line", "side", "severity", "body"],
        "additionalProperties": false,
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "line": {"type": "integer", "minimum": 1},
          "side": {"enum": ["RIGHT", "LEFT"]},
          "severity": {
            "enum": ["critical", "important", "suggestion", "nit"]
          },
          "body": {"type": "string", "minLength": 1},
          "start_line": {"type": "integer", "minimum": 1},
          "start_side": {"enum": ["RIGHT", "LEFT"]},
          "suggestion": {"type": "string", "minLength": 1}
        }
      }
    },
    "tier_attestation": {
      "description": "GH-143: reviewer/merge-reviewer lane (or human) tier endorsement. Written only by the reviewer lane, never by the implementer lane.",
      "type": "object",
      "required": ["pr_tier", "attested", "basis"],
      "additionalProperties": false,
      "properties": {
        "pr_tier": {"enum": ["fastlane", "standard", "heavy"]},
        "attested": {"type": "boolean"},
        "basis": {"type": "string", "minLength": 1}
      }
    },
    "finding_classifications": {
      "description": "GH-143: reviewer-lane severity/mechanical classification of post-authorization findings. Written only by the reviewer/merge-reviewer lane (or human); implementer self-classification is not trusted.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["finding_ref", "severity", "mechanical"],
        "additionalProperties": false,
        "properties": {
          "finding_ref": {"type": "string", "minLength": 1},
          "severity": {"enum": ["critical", "important", "minor", "nit"]},
          "mechanical": {"type": "boolean"}
        }
      }
    },
    "tier_dispute": {
      "description": "GH-143: tier classification dispute marker. Only the reviewer/merge-reviewer lane (or human) may set or clear it; the implementer lane has no authority over this flag.",
      "type": "boolean"
    },
    "spec_alignment": {
      "type": "object",
      "required": ["status"],
      "additionalProperties": false,
      "properties": {
        "status": {"enum": ["matched", "drift", "not_applicable"]},
        "spec": {"type": ["string", "null"]},
        "details": {"type": "string", "minLength": 1}
      }
    }
  }
}
