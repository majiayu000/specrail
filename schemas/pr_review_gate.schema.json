{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specrail.local/schemas/pr_review_gate.schema.json",
  "title": "Pull Request Review Gate",
  "type": "object",
  "required": [
    "pr",
    "linked_issue",
    "readiness_label",
    "agent_review",
    "human_review",
    "verification"
  ],
  "additionalProperties": false,
  "properties": {
    "pr": {
      "type": "integer",
      "minimum": 1
    },
    "linked_issue": {
      "type": "integer",
      "minimum": 1
    },
    "readiness_label": {
      "enum": ["ready_to_implement"]
    },
    "spec_packet": {
      "type": ["string", "null"]
    },
    "agent_review": {
      "enum": ["passed", "findings", "skipped"]
    },
    "human_review": {
      "enum": ["pending", "approved", "changes_requested"]
    },
    "verification": {
      "type": "object",
      "required": ["commands", "result"],
      "additionalProperties": false,
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "result": {
          "enum": ["pending", "passed", "failed"]
        }
      }
    }
  }
}
