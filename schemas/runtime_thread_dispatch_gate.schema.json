{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specrail.local/schemas/runtime_thread_dispatch_gate.schema.json",
  "title": "Runtime Thread Dispatch Gate",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "explicit_thread_request": {
      "type": ["string", "boolean", "null"]
    },
    "native_subagents": {
      "type": ["string", "boolean", "null"]
    },
    "spawn_requirement": {
      "type": ["string", "boolean", "null"]
    },
    "fallback_mode": {
      "type": ["string", "null"]
    },
    "planned_native_threads": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "write_scope": {
            "type": "string",
            "minLength": 1
          },
          "spawn_status": {
            "type": "string",
            "minLength": 1
          },
          "no_spawn_reason": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "native_thread_evidence": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "spawned_agents": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "lane_id": {
                "type": "string",
                "minLength": 1
              },
              "spawn_tool": {
                "type": "string",
                "minLength": 1
              },
              "agent_id_or_thread_id": {
                "type": "string",
                "minLength": 1
              },
              "wait_evidence": {
                "type": "string",
                "minLength": 1
              },
              "close_evidence": {
                "type": "string",
                "minLength": 1
              },
              "result_collected": {
                "type": ["string", "boolean"]
              }
            }
          }
        },
        "fallback_reason": {
          "type": ["string", "null"]
        }
      }
    },
    "no_spawn_reason": {
      "type": ["string", "null"]
    }
  }
}
